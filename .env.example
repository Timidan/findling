# Findling — environment template. Copy to .env.local and fill in. Never commit real secrets.

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (Postgres + pgvector, Storage) ---
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""   # server-side only
DATABASE_URL=""                # postgres connection string (Drizzle)

# --- Google / YouTube import (OAuth, youtube.readonly) ---
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console,
# enable the "YouTube Data API v3", and add GOOGLE_OAUTH_REDIRECT_URI as an
# authorized redirect URI. Only needed for the YouTube-import demo path.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/creator/youtube/callback"
# Encrypts stored YouTube refresh tokens. Accepts a 64-char hex key, a 32-byte
# base64 key, or a passphrase (>=32 chars; scrypt-derived). Use a strong value:
# openssl rand -hex 32
YOUTUBE_TOKEN_ENC_KEY=""

# --- Wallet auth (SIWE sessions + agent keys) ---
# HMAC secret for signing session cookies, SIWE nonces, and agent-key hashing.
# REQUIRED in production. Must be >=32 chars (enforced in src/server/auth/secret.ts).
# Generate with: openssl rand -hex 32
AUTH_SESSION_SECRET=""

# --- Embeddings (semantic search; every provider emits 384-dim to match the schema) ---
#   local  = bge-small-en-v1.5 via transformers.js — offline, free, no key (default)
#   openai = text-embedding-3-small (needs OPENAI_API_KEY)
#   gemini = gemini-embedding-001  (needs GEMINI_API_KEY)
#   mock   = deterministic, non-semantic (tests/demo)
EMBEDDING_PROVIDER="local"
GEMINI_API_KEY=""              # only if EMBEDDING_PROVIDER=gemini (GOOGLE_API_KEY also accepted)
OPENAI_API_KEY=""             # only if EMBEDDING_PROVIDER=openai

# --- Payments: Circle Gateway / x402 on Arc Testnet ---
GATEWAY_FACILITATOR_URL="https://gateway-api-testnet.circle.com"
SELLER_ADDRESS=""              # platform Gateway seller wallet — REQUIRED; receives gross on every settle (x402 payTo)
SELLER_PRIVATE_KEY=""          # server-side ONLY — signs PAYOUTS (withdrawals). Buys settle gas-free without it. Must derive to SELLER_ADDRESS.
# Real on-chain payouts require this; otherwise withdrawals use the mock (refused in prod).
PAYMENT_PROVIDER="gateway_x402"
# Buyer wallets are connected client-side; Findling stores NO buyer private key.

# Hard server-side ceiling on the per-payout network fee, decimal USDC string.
# Caller-supplied maxFee is clamped to [0, this]. Defaults to "2.01" if unset.
WITHDRAW_MAX_FEE_USDC="2.01"

# --- Object storage ---
# Findling stores clips/posters/previews in a Supabase Storage bucket named
# "moments" (private). Create it before uploads/imports work.

# --- Clip worker (yt-dlp + ffmpeg) ---
CLIP_TMP_DIR="/tmp/findling-clips"

# --- MCP (stdio server: `pnpm mcp`) ---
# The local stdio MCP server authenticates as this agent bearer key. Issue one at
# /studio/agents (or POST /api/agent/auth). The hosted HTTP endpoint /api/mcp does
# NOT use this — it reads the key from the Authorization header per request.
FINDLING_AGENT_KEY=""
