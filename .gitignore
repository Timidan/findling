# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.key
*.p12
*.pfx

# local package-manager credentials
.npmrc
.pnpmrc

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but keep the placeholder template the README tells users to copy
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local-only hackathon brief — invite passphrase + internal status, never push
HACKATHON.md

# third-party hackathon Discord export / scratch — not part of the product
chats.txt

# internal AI-orchestration planning docs — keep local, not for public judges
docs/goals/
docs/superpowers/
docs/RUNBOOK.md
docs/TESTNET-READINESS.md

# local prototype notes
src/app/prototype/clip-timeline/NOTES.md

# editor / agent tool dirs — machine-local, no product value
.agents/
.codex/
.claude/
.impeccable/
.vscode/
